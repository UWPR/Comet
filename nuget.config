<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="ThermoFisher-local" value="./RealtimeSearch/ThermoNuGet" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="ThermoFisher-local">
      <package pattern="ThermoFisher.CommonCore.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
  <config>
    <!-- Restore into a repo-local folder instead of the per-user global cache.
         The GitHub Actions self-hosted runner service runs as LocalSystem, whose
         global cache lives under the protected C:\Windows\System32\config\systemprofile
         profile; packages restored there are not reliably readable by the C# compiler
         (CS0006) and go stale across runs. A workspace-local folder is wiped by
         actions/checkout each run and is readable by every build process. MSToolkit.vcxproj
         resolves its Thermo HintPaths against $(SolutionDir)packages to match. -->
    <add key="globalPackagesFolder" value="packages" />
  </config>
</configuration>
